#!/bin/sh

ENABLED=yes
PROG=/opt/bin/chur-keenetic
NAME=chur-keenetic
PIDFILE=/opt/var/run/$NAME.pid
LOGFILE=/opt/var/log/$NAME.log
LISTEN=${CHUR_LISTEN:-0.0.0.0:8088}
CONFIG_DIR=/opt/etc/chur-keenetic

package_installed() {
	opkg status "$1" 2>/dev/null | grep -q "^Status: .* installed"
}

remove_package() {
	pkg=$1
	if package_installed "$pkg"; then
		echo "Removing package $pkg"
		opkg remove "$pkg" || true
	fi
}

start() {
	[ "$ENABLED" = "yes" ] || exit 0
	[ -x "$PROG" ] || {
		echo "$PROG is not executable"
		exit 1
	}
	if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
		echo "$NAME is already running"
		return 0
	fi
	mkdir -p /opt/var/run /opt/var/log
	echo "Starting $NAME on $LISTEN"
	"$PROG" -listen "$LISTEN" >>"$LOGFILE" 2>&1 &
	echo $! >"$PIDFILE"
}

stop() {
	if [ ! -f "$PIDFILE" ]; then
		echo "$NAME is not running"
		return 0
	fi
	pid=$(cat "$PIDFILE")
	if kill -0 "$pid" 2>/dev/null; then
		echo "Stopping $NAME"
		kill "$pid"
		for _ in 1 2 3 4 5; do
			kill -0 "$pid" 2>/dev/null || break
			sleep 1
		done
		kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
	fi
	rm -f "$PIDFILE"
}

status() {
	if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
		echo "$NAME is running, pid $(cat "$PIDFILE")"
	else
		echo "$NAME is not running"
		return 1
	fi
}

remove_interfaces() {
	for conf in "$CONFIG_DIR"/amneziawg/*.conf; do
		[ -f "$conf" ] || continue
		iface=${conf##*/}
		iface=${iface%.conf}
		echo "Removing interface $iface"
		if [ -x /opt/bin/awg-quick ]; then
			/opt/bin/awg-quick down "$conf" >/dev/null 2>&1 || true
		fi
		if command -v ip >/dev/null 2>&1; then
			ip link delete "$iface" >/dev/null 2>&1 || true
			ip link delete "$(echo "$iface" | tr 'A-Z' 'a-z')" >/dev/null 2>&1 || true
		elif [ -x /opt/sbin/ip ]; then
			/opt/sbin/ip link delete "$iface" >/dev/null 2>&1 || true
			/opt/sbin/ip link delete "$(echo "$iface" | tr 'A-Z' 'a-z')" >/dev/null 2>&1 || true
		fi
		if command -v ndmc >/dev/null 2>&1; then
			ndmc -c "no interface $iface" >/dev/null 2>&1 || true
			case "$iface" in
				opkgtun[0-9]*)
					ndmc_iface="OpkgTun${iface#opkgtun}"
					ndmc -c "no interface $ndmc_iface" >/dev/null 2>&1 || true
					;;
			esac
		fi
	done
	if command -v ndmc >/dev/null 2>&1; then
		ndmc -c "system configuration save" >/dev/null 2>&1 || true
	fi
}

remove_data() {
	echo "Removing $NAME data"
	rm -rf "$CONFIG_DIR"
	rm -f "$PIDFILE" "$LOGFILE"
}

remove_all() {
	echo "Removing $NAME and managed packages"
	stop
	remove_interfaces
	remove_data

	remove_package chur
	remove_package chur-amneziawg
	remove_package chur-amneziawg-go
	remove_package chur-amneziawg-tools
	remove_package chur-keenetic
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		stop
		start
		;;
	status)
		status
		;;
	remove)
		remove_all
		;;
	*)
		echo "Usage: $0 {start|stop|restart|status|remove}"
		exit 1
		;;
esac
